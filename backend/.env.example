# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings
MONGODB_URI=mongodb://127.0.0.1:27017/woodentoy
USE_LOCAL_DB=true

# Security
JWT_SECRET=supersecretjwtkey123
JWT_REFRESH_SECRET=supersecretrefreshjwtkey123
FRONTEND_URL=http://localhost:5173

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_ALLOW_INSECURE_TLS=true

# Cashfree Payment Gateway (Sandbox / Test Mode)
CASHFREE_APP_ID=your_app_id
CASHFREE_SECRET_KEY=your_secret_key
CASHFREE_ENV=sandbox
CASHFREE_SANDBOX_URL=https://sandbox.cashfree.com/pg
CASHFREE_API_VERSION=2023-08-01
CASHFREE_ALLOW_INSECURE_TLS=true
